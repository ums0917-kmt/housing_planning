<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>太陽光発電 電気代シミュレーション</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0d1117; --surface:#161b22; --surface2:#1c2330;
    --border:#30363d; --text:#e6edf3; --muted:#7d8590;
    --sun:#f0a500; --sun-dim:#7a5200;
    --battery:#3fb950; --battery-dim:#1a4a23;
    --base:#58a6ff; --base-dim:#1a3a6e;
    --ev:#a371f7; --ev-dim:#3a1f6e;
    --fit:#f78166; --self:#79c0ff;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{background:var(--bg);color:var(--text);font-family:'Noto Sans JP',sans-serif;font-size:14px;line-height:1.6;min-height:100vh;padding:24px 16px 48px;}

  /* HEADER */
  .header{text-align:center;margin-bottom:22px;padding-bottom:18px;border-bottom:1px solid var(--border);}
  .header h1{font-size:clamp(15px,3.5vw,22px);font-weight:700;letter-spacing:.02em;margin-bottom:4px;}
  .hdr-tags{display:flex;flex-wrap:wrap;justify-content:center;gap:6px;margin-top:6px;}
  .hdr-tag{font-size:10px;font-family:'DM Mono',monospace;padding:2px 8px;border-radius:20px;background:var(--surface);border:1px solid var(--border);color:var(--muted);}
  .hdr-tag span{color:var(--sun);}

  /* SECTION CARD */
  .section-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:16px;}
  .section-heading{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px;}

  /* TOGGLE ROW */
  .ctrl-row{display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-bottom:10px;}
  .ctrl-label{font-size:12px;color:var(--muted);min-width:80px;}
  .seg-ctrl{display:flex;gap:4px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:3px;}
  .seg-btn{padding:5px 12px;border:none;border-radius:6px;background:transparent;color:var(--muted);font-family:'Noto Sans JP',sans-serif;font-size:12px;cursor:pointer;transition:all .15s;white-space:nowrap;}
  .seg-btn.active{background:var(--surface);color:var(--text);border:1px solid var(--border);}
  .seg-btn.active.fit-active{color:var(--fit);border-color:var(--fit);}
  .seg-btn.active.self-active{color:var(--self);border-color:var(--self);}
  .seg-btn.active.away-active{color:var(--sun);border-color:var(--sun);}
  .seg-btn.active.home-active{color:var(--battery);border-color:var(--battery);}

  /* PARAM SLIDERS */
  .params-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:18px;}
  .param-group label{display:flex;justify-content:space-between;align-items:center;font-size:11px;color:var(--muted);margin-bottom:6px;}
  .param-val{font-family:'DM Mono',monospace;font-size:12px;font-weight:500;}
  .val-panel{color:var(--sun);} .val-bat{color:var(--battery);} .val-cons{color:var(--base);} .val-ev{color:var(--ev);}
  input[type=range]{-webkit-appearance:none;width:100%;height:4px;border-radius:2px;background:var(--surface2);outline:none;cursor:pointer;}
  .rng-panel::-webkit-slider-thumb{-webkit-appearance:none;width:15px;height:15px;border-radius:50%;background:var(--sun);border:2px solid var(--bg);cursor:pointer;}
  .rng-bat::-webkit-slider-thumb  {-webkit-appearance:none;width:15px;height:15px;border-radius:50%;background:var(--battery);border:2px solid var(--bg);cursor:pointer;}
  .rng-cons::-webkit-slider-thumb {-webkit-appearance:none;width:15px;height:15px;border-radius:50%;background:var(--base);border:2px solid var(--bg);cursor:pointer;}
  .rng-ev::-webkit-slider-thumb   {-webkit-appearance:none;width:15px;height:15px;border-radius:50%;background:var(--ev);border:2px solid var(--bg);cursor:pointer;}
  .tick-row{display:flex;justify-content:space-between;margin-top:4px;font-size:9px;color:#3d4550;font-family:'DM Mono',monospace;}

  /* EV */
  .ev-toggle-row{display:flex;align-items:center;gap:10px;margin-bottom:12px;flex-wrap:wrap;}
  .switch{position:relative;display:inline-block;width:42px;height:22px;}
  .switch input{opacity:0;width:0;height:0;}
  .slider-sw{position:absolute;cursor:pointer;inset:0;background:var(--surface2);border:1px solid var(--border);border-radius:22px;transition:.2s;}
  .slider-sw:before{content:'';position:absolute;width:16px;height:16px;left:2px;bottom:2px;background:var(--muted);border-radius:50%;transition:.2s;}
  input:checked+.slider-sw{background:var(--ev-dim);border-color:var(--ev);}
  input:checked+.slider-sw:before{background:var(--ev);transform:translateX(20px);}
  .ev-params.disabled{opacity:.3;pointer-events:none;}
  .v2h-note{margin-top:8px;font-size:10px;color:var(--ev);background:var(--ev-dim);border-radius:6px;padding:5px 10px;display:none;}
  .v2h-note.show{display:block;}

  /* PRESETS */
  .preset-row{display:flex;flex-wrap:wrap;gap:5px;margin-top:14px;padding-top:12px;border-top:1px solid var(--border);}
  .preset-label{font-size:10px;color:var(--muted);align-self:center;margin-right:4px;}
  .preset-btn{padding:3px 9px;border-radius:20px;border:1px solid var(--border);background:var(--surface2);color:var(--muted);font-size:10px;font-family:'DM Mono',monospace;cursor:pointer;transition:all .15s;white-space:nowrap;}
  .preset-btn:hover{border-color:var(--sun);color:var(--sun);}

  /* RESULT CARDS */
  .scenarios{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:12px;margin-bottom:20px;}
  .card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px;position:relative;overflow:hidden;}
  .card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
  .card-base::before   {background:var(--base);}
  .card-solar::before  {background:var(--sun);}
  .card-battery::before{background:var(--battery);}
  .card-label{display:flex;align-items:center;gap:7px;margin-bottom:12px;}
  .card-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;}
  .card-base    .card-icon{background:var(--base-dim);}
  .card-solar   .card-icon{background:var(--sun-dim);}
  .card-battery .card-icon{background:var(--battery-dim);}
  .card-title{font-weight:700;font-size:12px;line-height:1.3;}
  .card-tag{margin-left:auto;font-size:9px;padding:2px 6px;border-radius:20px;font-family:'DM Mono',monospace;flex-shrink:0;}
  .card-base    .card-tag{background:var(--base-dim);color:var(--base);}
  .card-solar   .card-tag{background:var(--sun-dim);color:var(--sun);}
  .card-battery .card-tag{background:var(--battery-dim);color:var(--battery);}
  .annual-cost{font-family:'DM Mono',monospace;font-size:clamp(20px,3.5vw,28px);font-weight:500;letter-spacing:-.02em;margin-bottom:2px;}
  .card-base    .annual-cost{color:var(--base);}
  .card-solar   .annual-cost{color:var(--sun);}
  .card-battery .annual-cost{color:var(--battery);}
  .cost-label{color:var(--muted);font-size:10px;margin-bottom:10px;}
  .savings-badge{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:20px;font-size:10px;font-family:'DM Mono',monospace;margin-bottom:10px;}
  .savings-none    {background:var(--surface2);color:var(--muted);}
  .savings-positive{background:#1a3a1a;color:#3fb950;}
  .savings-negative{background:#3a1a1a;color:#f85149;}
  .divider{border:none;border-top:1px solid var(--border);margin:8px 0;}
  .detail-row{display:flex;justify-content:space-between;align-items:center;padding:2px 0;font-size:10px;}
  .detail-label{color:var(--muted);}
  .detail-value{font-family:'DM Mono',monospace;font-size:10px;}
  .ev-sub{font-size:10px;color:var(--ev);margin-top:4px;}

  /* BAR CHART */
  .bar-chart{display:flex;flex-direction:column;gap:9px;}
  .bar-row{display:flex;align-items:center;gap:8px;}
  .bar-label{width:145px;font-size:10px;color:var(--muted);flex-shrink:0;text-align:right;}
  .bar-track{flex:1;height:24px;background:var(--surface2);border-radius:5px;overflow:hidden;}
  .bar-fill{height:100%;border-radius:5px;display:flex;align-items:center;padding-left:7px;font-family:'DM Mono',monospace;font-size:10px;color:#000;font-weight:500;transition:width .5s cubic-bezier(.16,1,.3,1);min-width:52px;}
  .bar-base      {background:var(--base);}
  .bar-solar-fit {background:var(--fit);}
  .bar-solar-self{background:#f5c842;}
  .bar-bat-fit   {background:var(--battery);}
  .bar-bat-self  {background:#5ce875;}

  /* TABLE */
  .table-wrap{overflow-x:auto;}
  table{width:100%;border-collapse:collapse;font-size:10px;}
  th{background:var(--surface2);color:var(--muted);font-weight:500;padding:6px 7px;text-align:right;border-bottom:1px solid var(--border);white-space:nowrap;}
  th:first-child{text-align:left;}
  td{padding:4px 7px;text-align:right;border-bottom:1px solid #1c2330;font-family:'DM Mono',monospace;font-size:10px;}
  td:first-child{text-align:left;color:var(--muted);font-family:'Noto Sans JP';font-size:10px;}
  tr:hover td{background:var(--surface2);}
  .col-base {color:var(--base);}
  .col-solar{color:var(--sun);}
  .col-bat  {color:var(--battery);}
  .tfoot-row td{border-top:1px solid var(--border);border-bottom:none;font-weight:700;padding-top:7px;}

  /* SELF-RATE INFO */
  .sr-info{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;padding-top:10px;border-top:1px solid var(--border);}
  .sr-chip{font-size:10px;font-family:'DM Mono',monospace;padding:3px 9px;border-radius:20px;background:var(--surface2);border:1px solid var(--border);color:var(--muted);}
  .sr-chip span{color:var(--sun);}

  /* NOTE */
  .note{background:#1a1f2e;border:1px solid #2a3450;border-radius:8px;padding:11px 13px;font-size:10px;color:var(--muted);line-height:1.7;}
  .note strong{color:var(--text);}

  @media(max-width:600px){.bar-label{width:95px;}}
</style>
</head>
<body>

<div class="header">
  <h1>太陽光発電 電気代シミュレーション</h1>
  <div class="hdr-tags">
    <div class="hdr-tag">パネル <span id="hdr-panel">4.0kW</span></div>
    <div class="hdr-tag">蓄電池 <span id="hdr-bat">6.5kWh</span></div>
    <div class="hdr-tag">年間消費 <span id="hdr-cons">4,500kWh</span></div>
    <div class="hdr-tag" id="hdr-mode-tag">FIT売電 <span>16円/kWh</span></div>
    <div class="hdr-tag" id="hdr-occ-tag">昼間不在</div>
  </div>
</div>

<!-- ── CONTROL PANEL ── -->
<div class="section-card">
  <div class="section-heading">⚙️ 運用設定</div>

  <!-- 売電モード -->
  <div class="ctrl-row">
    <span class="ctrl-label">💴 売電方式</span>
    <div class="seg-ctrl">
      <button class="seg-btn active fit-active" id="btn-fit"  onclick="setSellMode('fit')">FIT売電（16円/kWh）</button>
      <button class="seg-btn"                   id="btn-self" onclick="setSellMode('nonfit')">非FIT（6円/kWh）</button>
    </div>
  </div>

  <!-- 在宅パターン -->
  <div class="ctrl-row">
    <span class="ctrl-label">🏠 昼間の在宅</span>
    <div class="seg-ctrl">
      <button class="seg-btn active away-active" id="btn-away" onclick="setOccupancy('away')">昼間不在（共働き等）</button>
      <button class="seg-btn"                    id="btn-home" onclick="setOccupancy('home')">昼間在室（在宅勤務等）</button>
    </div>
  </div>

  <!-- 自家消費率の説明 -->
  <div class="sr-info" id="sr-info"></div>
</div>

<!-- ── PARAMS ── -->
<div class="section-card">
  <div class="section-heading">📐 設備・消費パラメーター</div>
  <div class="params-grid">
    <div class="param-group">
      <label>☀️ 太陽光パネル容量 <span class="param-val val-panel" id="lbl-panel">4.0 kW</span></label>
      <input type="range" class="rng-panel" id="rng-panel" min="2" max="12" step="0.5" value="4" oninput="onParamChange()">
      <div class="tick-row"><span>2kW</span><span>4kW</span><span>6kW</span><span>8kW</span><span>10kW</span><span>12kW</span></div>
    </div>
    <div class="param-group">
      <label>🔋 蓄電池容量 <span class="param-val val-bat" id="lbl-bat">6.5 kWh</span></label>
      <input type="range" class="rng-bat" id="rng-bat" min="3" max="20" step="0.5" value="6.5" oninput="onParamChange()">
      <div class="tick-row"><span>3kWh</span><span>6.5</span><span>9.5</span><span>12.8</span><span>16</span><span>20kWh</span></div>
    </div>
    <div class="param-group">
      <label>🏠 年間消費電力量 <span class="param-val val-cons" id="lbl-cons">4,500 kWh</span></label>
      <input type="range" class="rng-cons" id="rng-cons" min="2000" max="8000" step="100" value="4500" oninput="onParamChange()">
      <div class="tick-row"><span>2,000</span><span>3,500</span><span>5,000</span><span>6,500</span><span>8,000</span></div>
    </div>
  </div>

  <!-- EV -->
  <div style="margin-top:16px;padding-top:14px;border-top:1px solid var(--border);">
    <div class="ev-toggle-row">
      <span style="font-size:12px;color:var(--muted);">🚗 EV充電</span>
      <label class="switch">
        <input type="checkbox" id="ev-toggle" onchange="onParamChange()">
        <span class="slider-sw"></span>
      </label>
      <span id="ev-on-tag"   style="display:none;font-size:10px;padding:2px 8px;border-radius:20px;background:var(--ev-dim);color:var(--ev);font-family:'DM Mono',monospace;">EV充電あり</span>
      <span id="ev-off-label" style="font-size:11px;color:var(--muted);">オフ</span>
    </div>
    <div class="ev-params disabled" id="ev-params">
      <div class="params-grid">
        <div class="param-group">
          <label>🚗 年間走行距離 <span class="param-val val-ev" id="lbl-ev-km">10,000 km</span></label>
          <input type="range" class="rng-ev" id="rng-ev-km" min="2000" max="30000" step="1000" value="10000" oninput="onParamChange()">
          <div class="tick-row"><span>2,000km</span><span>10,000</span><span>20,000</span><span>30,000km</span></div>
        </div>
        <div class="param-group">
          <label>⚡ 電費 <span class="param-val val-ev" id="lbl-ev-eff">7.0 km/kWh</span></label>
          <input type="range" class="rng-ev" id="rng-ev-eff" min="4" max="12" step="0.5" value="7" oninput="onParamChange()">
          <div class="tick-row"><span>4km/kWh</span><span>7</span><span>10</span><span>12km/kWh</span></div>
        </div>
        <div class="param-group">
          <label>☀️ 太陽光自己充電率 <span class="param-val val-ev" id="lbl-ev-solar">40 %</span></label>
          <input type="range" class="rng-ev" id="rng-ev-solar" min="0" max="100" step="5" value="40" oninput="onParamChange()">
          <div class="tick-row"><span>0%（夜間）</span><span>50%</span><span>100%（昼間）</span></div>
        </div>
      </div>
    </div>
    <div class="v2h-note" id="v2h-note">💡 <strong>V2H対応時：</strong>車からの給電も活用可能。停電バックアップにも機能します。</div>
  </div>

  <!-- PRESETS -->
  <div class="preset-row">
    <span class="preset-label">プリセット：</span>
    <button class="preset-btn" onclick="applyPreset(4,6.5,4500,false,'fit','away')">標準家庭 4kW</button>
    <button class="preset-btn" onclick="applyPreset(8.37,12.8,4500,false,'fit','away')">検討中 8.37kW+12.8kWh</button>
    <button class="preset-btn" onclick="applyPreset(8.37,12.8,4500,true,'fit','away',10000,7,40)">検討中＋EV</button>
    <button class="preset-btn" onclick="applyPreset(8.37,12.8,4500,false,'nonfit','home')">検討中 自家消費優先</button>
    <button class="preset-btn" onclick="applyPreset(6,9.5,5500,false,'fit','away')">大家族 6kW</button>
    <button class="preset-btn" onclick="applyPreset(4,6.5,3000,false,'fit','away')">省エネ家庭</button>
  </div>
</div>

<!-- RESULT CARDS -->
<div class="scenarios" id="cards-area"></div>

<!-- BAR CHART -->
<div class="section-card">
  <div class="section-heading">年間電気代・削減比較</div>
  <div class="bar-chart" id="bar-chart"></div>
</div>

<!-- MONTHLY TABLE -->
<div class="section-card">
  <div class="section-heading">月別シミュレーション</div>
  <div class="table-wrap"><table id="monthly-table"></table></div>
</div>

<div class="note">
  <strong>試算前提：</strong>
  買電単価 31円/kWh（関西電力従量電灯A）／FIT売電 16円/kWh・非FIT 6円/kWh／京都南部日照 1,150h/年。<br>
  <strong>自家消費率：</strong>昼間不在＝太陽光のみ28%・蓄電池あり62%、昼間在室＝太陽光のみ55%・蓄電池あり78%。蓄電池容量で±補正あり。<br>
  <strong>季節消費：</strong>冷暖房・給湯・照明を月別に積算して算出。<br>
  <strong>EV：</strong>年間走行距離÷電費で充電量を算出。自己充電率分は余剰発電から充当（FIT時は売電機会損失を計上）。<br>
  <strong>注意：</strong>実際の削減額は設置方角・影・家族構成・生活パターンにより変動します。
</div>

<script>
// ===== CONSTANTS =====
const PRICE_BUY   = 31;
const SELL_FIT    = 16;
const SELL_NONFIT = 6;
const SOLAR_HOURS = 1150;

// ===== 月別係数 =====
const monthlyIrr = [0.70,0.80,0.95,1.10,1.15,1.05,1.10,1.15,0.95,0.85,0.70,0.65];
const MONTHS     = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
const totalIrr   = monthlyIrr.reduce((a,b)=>a+b,0);

// ===== 季節別消費量 =====
// 月別消費内訳: [冷房, 暖房, 給湯追加, 照明追加, ベース]
// ベース消費を100とした相対値で構成し、年間合計が12になるよう正規化
// 京都府南部の気象特性を反映（冬寒・夏暑、梅雨あり）
const seasonalProfile = [
  // 冷房  暖房  給湯  照明  ベース  → 合計（正規化前）
  [0.00, 1.30, 0.40, 0.20, 1.00],  // 1月  冬ピーク
  [0.00, 1.10, 0.35, 0.15, 1.00],  // 2月
  [0.00, 0.50, 0.20, 0.05, 1.00],  // 3月
  [0.00, 0.10, 0.10, 0.00, 1.00],  // 4月  春最小
  [0.05, 0.00, 0.05, 0.00, 1.00],  // 5月
  [0.30, 0.00, 0.05, 0.00, 1.00],  // 6月  梅雨・冷房開始
  [0.90, 0.00, 0.05, 0.00, 1.00],  // 7月
  [1.20, 0.00, 0.05, 0.00, 1.00],  // 8月  夏ピーク
  [0.40, 0.00, 0.10, 0.00, 1.00],  // 9月
  [0.00, 0.10, 0.15, 0.05, 1.00],  // 10月 秋最小
  [0.00, 0.50, 0.25, 0.10, 1.00],  // 11月
  [0.00, 1.10, 0.35, 0.20, 1.00],  // 12月
];
const rawMonthlyLoad = seasonalProfile.map(m => m.reduce((a,b)=>a+b,0));
const totalLoad      = rawMonthlyLoad.reduce((a,b)=>a+b,0);
const monthlyConsRatio = rawMonthlyLoad.map(v => v / totalLoad * 12); // 合計=12に正規化

// ===== 自家消費率テーブル =====
// occupancy: 'away'（昼間不在）/ 'home'（昼間在室）
// 蓄電池容量で±補正（6.5kWh基準）
const SR_BASE = {
  away: { solar: 0.28, bat: 0.62 },
  home: { solar: 0.55, bat: 0.78 },
};

function getSelfRate(type, batKwh) {
  // type: 'solar' or 'bat'
  const base  = SR_BASE[occupancy][type];
  const delta = type === 'bat' ? (batKwh - 6.5) / 13.5 * 0.10 : 0;
  return Math.min(Math.max(base + delta, 0.10), 0.95);
}

// ===== STATE =====
let sellMode  = 'fit';     // 'fit' | 'nonfit'
let occupancy = 'away';    // 'away' | 'home'
let panelKw   = 4.0;
let batKwh    = 6.5;
let annualKwh = 4500;
let evOn      = false;
let evKmYear  = 10000;
let evEffKm   = 7.0;
let evSolarPct= 40;

function sellPrice() { return sellMode === 'fit' ? SELL_FIT : SELL_NONFIT; }

// ===== EV COST =====
function evAnnualKwh() { return evKmYear / evEffKm; }

function calcEvCost(hasSolar, hasBat) {
  if (!evOn) return 0;
  const total = evAnnualKwh();
  if (!hasSolar) return total * PRICE_BUY;
  const solarFrac = Math.min((evSolarPct + (hasBat ? 10 : 0)) / 100, 1.0);
  const gridFrac  = 1 - solarFrac;
  // FIT時のみ売電機会損失を計上
  const oppCost   = sellMode === 'fit' ? total * solarFrac * sellPrice() : 0;
  return total * gridFrac * PRICE_BUY + oppCost;
}

// ===== MONTHLY CALC =====
function calcMonthly() {
  const srSolar = getSelfRate('solar', batKwh);
  const srBat   = getSelfRate('bat',   batKwh);
  const sp      = sellPrice();
  const totalConsRatio = monthlyConsRatio.reduce((a,b)=>a+b,0); // =12

  return MONTHS.map((m, i) => {
    const cons = annualKwh * monthlyConsRatio[i] / totalConsRatio;
    const gen  = panelKw  * SOLAR_HOURS * monthlyIrr[i] / totalIrr;

    const baseCost = cons * PRICE_BUY;

    // 太陽光のみ
    const selfSolar = Math.min(gen * srSolar, cons);
    const sellSolar = gen - selfSolar;
    const gridSolar = Math.max(0, cons - selfSolar);
    const solarCost = gridSolar * PRICE_BUY - sellSolar * sp;

    // 太陽光+蓄電池
    const selfBat = Math.min(gen * srBat, cons);
    const sellBat = gen - selfBat;
    const gridBat = Math.max(0, cons - selfBat);
    const batCost = gridBat * PRICE_BUY - sellBat * sp;

    // EV月割り（月別比率で配分）
    const evBase  = evOn ? calcEvCost(false,false) * monthlyConsRatio[i] / totalConsRatio : 0;
    const evSolar = evOn ? calcEvCost(true, false) * monthlyConsRatio[i] / totalConsRatio : 0;
    const evBat   = evOn ? calcEvCost(true, true)  * monthlyConsRatio[i] / totalConsRatio : 0;

    const totalBase  = baseCost  + evBase;
    const totalSolar = solarCost + evSolar;
    const totalBat   = batCost   + evBat;

    return {
      month: m,
      cons:  Math.round(cons),
      gen:   Math.round(gen),
      srSolar: Math.round(selfSolar / gen * 100) || 0,
      srBat:   Math.round(selfBat   / gen * 100) || 0,
      sellIncSolar:  Math.round(sellSolar * sp),   // 太陽光のみ 売電収入
      sellIncBat:    Math.round(sellBat   * sp),   // 蓄電池あり 売電収入
      sellKwhSolar:  Math.round(sellSolar),        // 売電量(kWh)
      sellKwhBat:    Math.round(sellBat),
      gridKwhSolar:  Math.round(gridSolar),        // 買電量(kWh)
      gridKwhBat:    Math.round(gridBat),
      gridCostSolar: Math.round(gridSolar * PRICE_BUY), // 買電コスト(円)
      gridCostBat:   Math.round(gridBat   * PRICE_BUY),
      baseCost:    Math.round(totalBase),
      solarCost:   Math.round(totalSolar),
      batteryCost: Math.round(totalBat),
      savingSolar:   Math.round(totalBase - totalSolar),
      savingBattery: Math.round(totalBase - totalBat),
    };
  });
}

function sum(rows, f) { return rows.reduce((a,r)=>a+r[f],0); }
function fmt(n) { return Math.abs(n).toLocaleString()+'円'; }
function badgeCls(v){ return v>0?'savings-positive':v<0?'savings-negative':'savings-none'; }
function badgeTxt(v){ if(!v) return '— 変化なし'; return (v>0?'▼ ':'▲ ')+fmt(v)+(v>0?' 削減':' 増加'); }

// ===== UI SETTERS =====
function setSellMode(m) {
  sellMode = m;
  document.getElementById('btn-fit').classList.toggle('active',   m==='fit');
  document.getElementById('btn-fit').classList.toggle('fit-active', m==='fit');
  document.getElementById('btn-self').classList.toggle('active',  m==='nonfit');
  document.getElementById('btn-self').classList.toggle('self-active', m==='nonfit');
  updateHdrTags(); render();
}

function setOccupancy(o) {
  occupancy = o;
  document.getElementById('btn-away').classList.toggle('active',     o==='away');
  document.getElementById('btn-away').classList.toggle('away-active',o==='away');
  document.getElementById('btn-home').classList.toggle('active',     o==='home');
  document.getElementById('btn-home').classList.toggle('home-active',o==='home');
  updateHdrTags(); render();
}

function applyPreset(panel,bat,cons,ev,sell,occ,km=10000,eff=7,sol=40){
  panelKw=panel; batKwh=bat; annualKwh=cons;
  evOn=ev; evKmYear=km; evEffKm=eff; evSolarPct=sol;
  sellMode=sell; occupancy=occ;
  document.getElementById('rng-panel').value=panel;
  document.getElementById('rng-bat').value=bat;
  document.getElementById('rng-cons').value=cons;
  document.getElementById('ev-toggle').checked=ev;
  document.getElementById('rng-ev-km').value=km;
  document.getElementById('rng-ev-eff').value=eff;
  document.getElementById('rng-ev-solar').value=sol;
  // sync seg btns
  ['fit','nonfit'].forEach(m=>{
    document.getElementById('btn-'+( m==='fit'?'fit':'self')).classList.toggle('active',sellMode===m);
    document.getElementById('btn-'+(m==='fit'?'fit':'self')).classList.toggle((m==='fit'?'fit':'self')+'-active',sellMode===m);
  });
  document.getElementById('btn-away').classList.toggle('active',occ==='away');
  document.getElementById('btn-away').classList.toggle('away-active',occ==='away');
  document.getElementById('btn-home').classList.toggle('active',occ==='home');
  document.getElementById('btn-home').classList.toggle('home-active',occ==='home');
  updateEvUI(); updateLabels(); render();
}

function updateEvUI(){
  const on=document.getElementById('ev-toggle').checked;
  document.getElementById('ev-params').classList.toggle('disabled',!on);
  document.getElementById('ev-on-tag').style.display   =on?'inline':'none';
  document.getElementById('ev-off-label').style.display=on?'none':'inline';
  document.getElementById('v2h-note').classList.toggle('show',on);
}

function updateHdrTags(){
  document.getElementById('hdr-mode-tag').innerHTML =
    sellMode==='fit' ? 'FIT売電 <span>16円/kWh</span>' : '非FIT売電 <span>6円/kWh</span>';
  document.getElementById('hdr-occ-tag').textContent =
    occupancy==='away' ? '昼間不在' : '昼間在室';
}

function updateLabels(){
  document.getElementById('lbl-panel').textContent  = panelKw.toFixed(1)+' kW';
  document.getElementById('lbl-bat').textContent    = batKwh.toFixed(1)+' kWh';
  document.getElementById('lbl-cons').textContent   = annualKwh.toLocaleString()+' kWh';
  document.getElementById('lbl-ev-km').textContent  = evKmYear.toLocaleString()+' km';
  document.getElementById('lbl-ev-eff').textContent = evEffKm.toFixed(1)+' km/kWh';
  document.getElementById('lbl-ev-solar').textContent= evSolarPct+' %';
  document.getElementById('hdr-panel').textContent  = panelKw.toFixed(1)+'kW';
  document.getElementById('hdr-bat').textContent    = batKwh.toFixed(1)+'kWh';
  document.getElementById('hdr-cons').textContent   = annualKwh.toLocaleString()+'kWh';
}

function onParamChange(){
  panelKw   = parseFloat(document.getElementById('rng-panel').value);
  batKwh    = parseFloat(document.getElementById('rng-bat').value);
  annualKwh = parseInt  (document.getElementById('rng-cons').value);
  evOn      = document.getElementById('ev-toggle').checked;
  evKmYear  = parseInt  (document.getElementById('rng-ev-km').value);
  evEffKm   = parseFloat(document.getElementById('rng-ev-eff').value);
  evSolarPct= parseInt  (document.getElementById('rng-ev-solar').value);
  updateEvUI(); updateLabels(); render();
}

// ===== RENDER =====
function render(){
  const rows    = calcMonthly();
  const aBase   = sum(rows,'baseCost');
  const aSolar  = sum(rows,'solarCost');
  const aBat    = sum(rows,'batteryCost');
  const sSolar  = aBase - aSolar;
  const sBat    = aBase - aBat;
  const annualGen = Math.round(panelKw * SOLAR_HOURS);
  const sp        = sellPrice();
  const srSolar   = getSelfRate('solar', batKwh);
  const srBat     = getSelfRate('bat',   batKwh);
  const modeLabel = sellMode==='fit' ? `FIT ${sp}円/kWh` : `非FIT ${sp}円/kWh`;
  const occLabel  = occupancy==='away' ? '昼間不在' : '昼間在室';

  // SR INFO CHIPS
  document.getElementById('sr-info').innerHTML = `
    <div class="sr-chip">太陽光のみ 自家消費率 <span>${Math.round(srSolar*100)}%</span></div>
    <div class="sr-chip">蓄電池あり 自家消費率 <span>${Math.round(srBat*100)}%</span></div>
    <div class="sr-chip">売電単価 <span>${sp}円/kWh</span></div>
    <div class="sr-chip">買電単価 <span>31円/kWh</span></div>
  `;

  const evKwh       = evOn ? Math.round(evAnnualKwh()) : 0;
  const evCostBase  = evOn ? Math.round(calcEvCost(false,false)) : 0;
  const evCostSolar = evOn ? Math.round(calcEvCost(true, false)) : 0;
  const evCostBat   = evOn ? Math.round(calcEvCost(true, true))  : 0;
  const evSubBase   = evOn ? `<div class="ev-sub">うちEV充電 ${evCostBase.toLocaleString()}円</div>` : '';
  const evSubSolar  = evOn ? `<div class="ev-sub">うちEV充電 ${evCostSolar.toLocaleString()}円</div>` : '';
  const evSubBat    = evOn ? `<div class="ev-sub">うちEV充電 ${evCostBat.toLocaleString()}円</div>` : '';

  // 年間集計
  const annualSellIncSolar  = sum(rows,'sellIncSolar');
  const annualSellIncBat    = sum(rows,'sellIncBat');
  const annualSellKwhSolar  = sum(rows,'sellKwhSolar');
  const annualSellKwhBat    = sum(rows,'sellKwhBat');
  const annualGridKwhSolar  = sum(rows,'gridKwhSolar');
  const annualGridKwhBat    = sum(rows,'gridKwhBat');
  // 買電コスト（EV除く家庭分）
  const annualGridCostSolar = annualGridKwhSolar * PRICE_BUY;
  const annualGridCostBat   = annualGridKwhBat   * PRICE_BUY;

  // 収入超過かどうか（売電収入 > 買電コスト）
  const netSolar = aSolar;  // 正=支出, 負=収入超過
  const netBat   = aBat;

  function fmtNet(n) {
    // n>0: 支出（電気代）→ そのまま正表示
    // n<0: 収入超過 → マイナス表示（黒字）
    if (n >= 0) return n.toLocaleString() + '円';
    return '−' + Math.abs(n).toLocaleString() + '円';
  }
  function netColor(n, baseColor) {
    return n < 0 ? 'var(--battery)' : baseColor;
  }
  function netLabel(n) {
    return n < 0 ? '年間収支（売電収入が上回り黒字）' : '年間電気代（売電収入差引後）';
  }
  function fmtNetMonth(n) {
    if (n >= 0) return fmt(Math.round(n/12));
    return '−' + Math.abs(Math.round(n/12)).toLocaleString() + '円';
  }

  // CARDS
  document.getElementById('cards-area').innerHTML = `
    <div class="card card-base">
      <div class="card-label">
        <div class="card-icon">🔌</div>
        <div class="card-title">太陽光なし${evOn?' + EV':''}</div>
        <span class="card-tag">ベース</span>
      </div>
      <div class="annual-cost">${fmt(aBase)}</div>
      <div class="cost-label">年間電気代${evOn?' (EV含む)':''}</div>
      <span class="savings-badge savings-none">— 基準値</span>
      ${evSubBase}
      <hr class="divider">
      <div class="detail-row"><span class="detail-label">月平均</span><span class="detail-value">${fmt(Math.round(aBase/12))}</span></div>
      <div class="detail-row"><span class="detail-label">年間消費量</span><span class="detail-value">${annualKwh.toLocaleString()} kWh</span></div>
      ${evOn?`<div class="detail-row"><span class="detail-label">EV充電量</span><span class="detail-value">${evKwh.toLocaleString()} kWh/年</span></div>`:''}
    </div>

    <div class="card card-solar">
      <div class="card-label">
        <div class="card-icon">☀️</div>
        <div class="card-title">太陽光 ${panelKw.toFixed(1)}kW${evOn?' + EV':''}</div>
        <span class="card-tag">${modeLabel}</span>
      </div>
      <div class="annual-cost" style="color:${netColor(netSolar,'var(--sun)')}">${fmtNet(netSolar)}</div>
      <div class="cost-label">${netLabel(netSolar)}</div>
      <span class="savings-badge ${badgeCls(sSolar)}">${badgeTxt(sSolar)}</span>
      ${evSubSolar}
      <hr class="divider">
      <div class="detail-row"><span class="detail-label">月平均</span><span class="detail-value" style="color:${netColor(netSolar,'inherit')}">${fmtNetMonth(netSolar)}</span></div>
      <div class="detail-row"><span class="detail-label">年間発電量</span><span class="detail-value">${annualGen.toLocaleString()} kWh</span></div>
      <div class="detail-row"><span class="detail-label">自家消費率</span><span class="detail-value">${Math.round(srSolar*100)}% (${occLabel})</span></div>
      <hr class="divider">
      <div class="detail-row" style="color:var(--sun)"><span class="detail-label">💴 売電収入</span><span class="detail-value">+${annualSellIncSolar.toLocaleString()}円</span></div>
      <div class="detail-row"><span class="detail-label">　売電量</span><span class="detail-value">${annualSellKwhSolar.toLocaleString()} kWh</span></div>
      <div class="detail-row"><span class="detail-label">🔌 買電コスト</span><span class="detail-value">${(sum(rows,'gridCostSolar')).toLocaleString()}円</span></div>
      <div class="detail-row"><span class="detail-label">　買電量</span><span class="detail-value">${annualGridKwhSolar.toLocaleString()} kWh</span></div>
      <div class="detail-row"><span class="detail-label">削減率</span><span class="detail-value">${Math.round(sSolar/aBase*100)}%</span></div>
    </div>

    <div class="card card-battery">
      <div class="card-label">
        <div class="card-icon">🔋</div>
        <div class="card-title">太陽光＋蓄電池 ${batKwh.toFixed(1)}kWh${evOn?' + EV':''}</div>
        <span class="card-tag">${modeLabel}</span>
      </div>
      <div class="annual-cost" style="color:${netColor(netBat,'var(--battery)')}">${fmtNet(netBat)}</div>
      <div class="cost-label">${netLabel(netBat)}</div>
      <span class="savings-badge ${badgeCls(sBat)}">${badgeTxt(sBat)}</span>
      ${evSubBat}
      <hr class="divider">
      <div class="detail-row"><span class="detail-label">月平均</span><span class="detail-value" style="color:${netColor(netBat,'inherit')}">${fmtNetMonth(netBat)}</span></div>
      <div class="detail-row"><span class="detail-label">自家消費率</span><span class="detail-value">${Math.round(srBat*100)}% (${occLabel})</span></div>
      <hr class="divider">
      <div class="detail-row" style="color:var(--battery)"><span class="detail-label">💴 売電収入</span><span class="detail-value">+${annualSellIncBat.toLocaleString()}円</span></div>
      <div class="detail-row"><span class="detail-label">　売電量</span><span class="detail-value">${annualSellKwhBat.toLocaleString()} kWh</span></div>
      <div class="detail-row"><span class="detail-label">🔌 買電コスト</span><span class="detail-value">${(sum(rows,'gridCostBat')).toLocaleString()}円</span></div>
      <div class="detail-row"><span class="detail-label">　買電量</span><span class="detail-value">${annualGridKwhBat.toLocaleString()} kWh</span></div>
      <div class="detail-row"><span class="detail-label">削減率</span><span class="detail-value">${Math.round(sBat/aBase*100)}%</span></div>
    </div>
  `;

  // BAR CHART — 電気代と売電収入を別セクションで表示
  const maxCost = Math.max(aBase, aSolar, aBat);
  const maxSell = Math.max(annualSellIncSolar, annualSellIncBat, 1);
  const barCls  = sellMode==='fit' ? ['bar-base','bar-solar-fit','bar-bat-fit'] : ['bar-base','bar-solar-self','bar-bat-self'];
  const costBars = [
    {label:'ベース（太陽光なし）',      val:aBase,  cls:barCls[0]},
    {label:`太陽光のみ（${modeLabel}）`, val:aSolar, cls:barCls[1]},
    {label:`＋蓄電池（${modeLabel}）`,   val:aBat,   cls:barCls[2]},
  ];
  const sellBars = [
    {label:`太陽光のみ 売電収入`,  val:annualSellIncSolar, cls:barCls[1]},
    {label:`＋蓄電池 売電収入`,    val:annualSellIncBat,   cls:barCls[2]},
  ];
  document.getElementById('bar-chart').innerHTML =
    `<div style="font-size:10px;color:var(--muted);margin-bottom:6px;">▌ 年間電気代（低いほど良い）</div>` +
    costBars.map(b=>`
      <div class="bar-row">
        <div class="bar-label">${b.label}</div>
        <div class="bar-track">
          <div class="bar-fill ${b.cls}" style="width:${Math.max(5,Math.round(b.val/maxCost*100))}%">${fmt(b.val)}</div>
        </div>
      </div>
    `).join('') +
    `<div style="font-size:10px;color:var(--muted);margin:12px 0 6px;">▌ 年間売電収入（高いほど良い）</div>` +
    sellBars.map(b=>`
      <div class="bar-row">
        <div class="bar-label">${b.label}</div>
        <div class="bar-track">
          <div class="bar-fill ${b.cls}" style="width:${Math.max(5,Math.round(b.val/maxSell*100))}%">+${b.val.toLocaleString()}円</div>
        </div>
      </div>
    `).join('');

  // TABLE
  const thead = `<thead><tr>
    <th>月</th><th>消費<br>kWh</th><th>発電<br>kWh</th>
    <th class="col-solar">売電量<br>太陽光<br>kWh</th>
    <th class="col-solar">売電収入<br>太陽光<br>円</th>
    <th class="col-solar">買電コスト<br>太陽光<br>円</th>
    <th class="col-bat">売電量<br>蓄電池<br>kWh</th>
    <th class="col-bat">売電収入<br>蓄電池<br>円</th>
    <th class="col-bat">買電コスト<br>蓄電池<br>円</th>
    <th class="col-base">ベース<br>円</th>
    <th class="col-solar">太陽光<br>収支円</th><th class="col-solar">削減<br>円</th>
    <th class="col-bat">＋蓄電池<br>収支円</th><th class="col-bat">削減<br>円</th>
  </tr></thead>`;

  function cellNet(v) {
    if (v >= 0) return v.toLocaleString();
    return '<span style="color:var(--battery)">−' + Math.abs(v).toLocaleString() + '</span>';
  }

  const tbody = '<tbody>' + rows.map(r=>`<tr>
    <td>${r.month}</td><td>${r.cons}</td><td>${r.gen}</td>
    <td class="col-solar">${r.sellKwhSolar.toLocaleString()}</td>
    <td class="col-solar">+${r.sellIncSolar.toLocaleString()}</td>
    <td class="col-solar">${r.gridCostSolar.toLocaleString()}</td>
    <td class="col-bat">${r.sellKwhBat.toLocaleString()}</td>
    <td class="col-bat">+${r.sellIncBat.toLocaleString()}</td>
    <td class="col-bat">${r.gridCostBat.toLocaleString()}</td>
    <td class="col-base">${r.baseCost.toLocaleString()}</td>
    <td class="col-solar">${cellNet(r.solarCost)}</td>
    <td class="col-solar">▼${r.savingSolar.toLocaleString()}</td>
    <td class="col-bat">${cellNet(r.batteryCost)}</td>
    <td class="col-bat">▼${r.savingBattery.toLocaleString()}</td>
  </tr>`).join('') + '</tbody>';

  const annualGridCostSolarTotal = sum(rows,'gridCostSolar');
  const annualGridCostBatTotal   = sum(rows,'gridCostBat');

  const tfoot = `<tfoot><tr class="tfoot-row">
    <td>年間</td><td>${annualKwh.toLocaleString()}</td><td>${annualGen.toLocaleString()}</td>
    <td class="col-solar">${annualSellKwhSolar.toLocaleString()}</td>
    <td class="col-solar">+${annualSellIncSolar.toLocaleString()}</td>
    <td class="col-solar">${annualGridCostSolarTotal.toLocaleString()}</td>
    <td class="col-bat">${annualSellKwhBat.toLocaleString()}</td>
    <td class="col-bat">+${annualSellIncBat.toLocaleString()}</td>
    <td class="col-bat">${annualGridCostBatTotal.toLocaleString()}</td>
    <td class="col-base">${aBase.toLocaleString()}</td>
    <td class="col-solar">${cellNet(aSolar)}</td>
    <td class="col-solar">▼${sSolar.toLocaleString()}</td>
    <td class="col-bat">${cellNet(aBat)}</td>
    <td class="col-bat">▼${sBat.toLocaleString()}</td>
  </tr></tfoot>`;

  document.getElementById('monthly-table').innerHTML = thead+tbody+tfoot;
}

render();
</script>
</body>
</html>
